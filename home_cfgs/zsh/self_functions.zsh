# =========================================================
# 自定义函数主文件
# 说明：
# 1. 当前文件中直接存放主要函数定义
# 2. 如果存在 functions 目录，则额外自动加载其中的扩展文件
# =========================================================

# ---------------------------------------------------------
# 下面是你原本的大量函数定义
# ---------------------------------------------------------

# foo() {
#     echo "foo"
# }
#
# _foo_helper() {
#     echo "helper"
# }

# 这里继续放你现有的大量函数……
# ... ...

# ---------------------------------------------------------
# 自动加载扩展函数文件
# ---------------------------------------------------------
# 当前 function.zsh 文件所在目录
__function_zsh_file=${(%):-%N}
__function_zsh_dir=${__function_zsh_file:A:h}

# 自动加载扩展函数目录中的 .zsh 文件
if [[ -d "${__function_zsh_dir}/functions" ]]; then
    typeset file
    for file in "${__function_zsh_dir}"/functions/*.zsh(N); do
        source "$file"
    done
fi

unset __function_zsh_file __function_zsh_dir file
